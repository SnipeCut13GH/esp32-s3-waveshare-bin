#include <Arduino_GFX_Library.h> #include <Wire.h> #define BL 15 Arduino_DataBus *bus = new Arduino_ESP32LCD8780(11, 10, 12, 13, 14, 35, 36, 37, 38, 39, 40, 41, 42); Arduino_GFX *gfx = new Arduino_ST7789(bus, 1, 3, true, 240, 280, 0, 20); void setup() { Wire.begin(8, 9); // Safety: 200mA charging for your 200mAh battery Wire.beginTransmission(0x34); Wire.write(0x62); Wire.write(0x02); Wire.endTransmission(); pinMode(BL, OUTPUT); digitalWrite(BL, HIGH); gfx->begin(); gfx->fillScreen(BLACK); } void loop() { float v = (analogRead(1) / 4095.0) * 2.0 * 3.3 * 1.1; int p = map(constrain(v * 100, 330, 420), 330, 420, 0, 100); gfx->fillScreen(BLACK); gfx->setCursor(40, 100); gfx->setTextSize(5); if (p > 20) gfx->setTextColor(GREEN); else gfx->setTextColor(RED); gfx->printf("%d%%", p); gfx->setTextSize(2); gfx->setCursor(60, 180); gfx->setTextColor(WHITE); gfx->printf("%.2fV", v); delay(2000); }
